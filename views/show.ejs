<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UserBase — All Users</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body>

    <nav>
        <a href="/postnest" class="brand" style="color: #A855F7;">
            <img src="/PostNest.png" alt="PostNest logo">
            PostNest
        </a>

        <a href="/postnest"> <i class="fa-solid fa-house"></i> Home</a>
        <a href="/users"> <i class="fa-solid fa-user"></i>  Users</a>
    </nav>

    <div class="page">

        <div class="page-header">
            <h1>All <span class="accent">Users</span></h1>
            <p class="subtitle"><%= users.length %> user<%= users.length !== 1 ? 's' : '' %> found in the database.</p>
        </div>

        <a href="/users/new" class="new">Create New Post</a>

        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Post</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% for(let user of users) { %>
                        <tr>
                            <td class="id-cell" data-label="ID"><%= user.id %></td>
                            <td class="username-cell" data-label="Username"><%= user.username %></td>
                            <td class="email-cell" data-label="Email"><%= user.email %></td>
                            <td class="content-cell" data-label="Content"><%= user.content %></td>
                        
                            <td data-label="Actions">
                                <form method="get" action="/users/<%= user.id %>/view" style="display:inline;">
                                    <button class="btn btn-ghost btn-sm" type="submit">View</button>
                                </form>
                                <form method="get" action="/users/<%= user.id %>/edit" style="display:inline;">
                                    <button class="btn btn-edit btn-sm" type="submit">Edit</button>
                                </form>
                                <button class="btn btn-delete btn-sm" onclick="confirmDelete('<%= user.id %>', '<%= user.password %>')">Delete</button>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
                            
            </table>
        </div>

    </div>

    <!-- Toast Notification for correct password -->
    <div id="toast" class="toast" style="display:none;">
        <div class="toast-icon">✓</div>
        <div>
            <div class="toast-text">Username updated</div>
            <div class="toast-subtext">Changes saved successfully.</div>
        </div>
    </div>

    <!-- error toast for wrong password -->
    <div id="toast-error" class="toast toast-error" style="display:none;">
        <div class="toast-icon">✕</div>
        <div>
            <div class="toast-text">Wrong password ! Try Again</div>
            <div class="toast-subtext">The password you entered is incorrect.</div>
        </div> 
    </div> 

    <script src="/app.js"></script>

</body>
</html>
