<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UserBase — Edit User</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <nav>
        <a href="/postnest" class="brand" style="color: #D946EF;">
            <img src="/PostNest.png" alt="PostNest logo">
            PostNest 
        </a>
        <a href="/postnest">Home</a>
        <a href="/users">Users</a>
    </nav>
 
    <div class="page-edit">
        

        <div class="page-header">
            <h1>Edit <span class="accent">Username & Email</span></h1>
            <p class="subtitle">Update the username for this account. Password is required to confirm.</p>
        </div>

        <div class="edit-target">✉ <%= user.email %></div>

        <div class="form-card">
            <form method="post" action="/users/<%= user.id %>/edit?_method=PUT">

                <div class="form-group">
                    <label for="username">Edit Username</label>
                    <input
                        type="text"
                        name="username",
                        id="username",
                        value="<%= user.username.trim() %>"
                        placeholder="Enter new username"
                        autocomplete="off"
                        required
                    >
                    <br> <br>
                    <label for="email">Edit Email</label>
                    <input type="email" name="email" 
                        id="email",
                        value="<%= user.email.trim() %>"
                        placeholder="Enter new email"
                        autocomplete="off"
                    ><br> <br>
                    <label for="content">Edit your content</label>
                    <textarea name="content" id=""> <%= user.content %> </textarea>
                </div>

                <div class="form-group">
                    <label for="password">Current Password</label>
                    <input
                        type="password"
                        id="password"
                        name="password"
                        placeholder="Enter your password to confirm"
                        required
                    >
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a href="/users" class="btn btn-ghost">Cancel</a>
                </div>

            </form>
        </div>

    </div>


    
</body>
</html>
